# ============================================================================
# HireSignal - environment configuration (EXAMPLE)
# Copy to `.env` and fill real values.  `.env` is gitignored; this file is not.
# Each variable is tagged with the phase where it first becomes relevant.
# ============================================================================

# ---- App (Phase 1) ----
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

# ---- Security / JWT (Phase 3) ----
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-hex-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256

# ---- PostgreSQL (Phase 1) ----
POSTGRES_USER=hiresignal
POSTGRES_PASSWORD=hiresignal_dev_pw
POSTGRES_DB=hiresignal
POSTGRES_HOST=postgres          # service name inside the Docker network
POSTGRES_PORT=5432
# SQLAlchemy async URL (assembled from the parts above)
DATABASE_URL=postgresql+asyncpg://hiresignal:hiresignal_dev_pw@postgres:5432/hiresignal

# ---- Redis (Phase 1, used Phase 3) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300           # 5-min cache-aside TTL for GET endpoints

# ---- LLM provider (Phase 4) - primary + automatic fallback ----
LLM_PROVIDER=google
GOOGLE_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash-lite
# On any primary failure, fall back to these providers in order:
LLM_FALLBACK_PROVIDERS=deepseek
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
# Switch primary by changing LLM_PROVIDER and filling the matching vars:
ANTHROPIC_API_KEY=sk-ant-...your-key...
ANTHROPIC_MODEL=claude-sonnet-5

# ---- Embeddings / RAG (Phase 5) ----
EMBEDDING_MODEL=all-MiniLM-L6-v2   # sentence-transformers, runs locally, free
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVE_TOP_K=5

# ---- ChromaDB (Phase 5) ----
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=resumes

# ---- Object storage / S3 (Phase 6; local via MinIO, real AWS in Phase 11) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
S3_BUCKET=hiresignal-resumes
S3_ENDPOINT_URL=http://minio:9000   # remove for real AWS

# ---- Kafka (Phase 9) ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_ANALYSIS=resume-analysis
KAFKA_CONSUMER_GROUP=analysis-workers
